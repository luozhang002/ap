DATABASE_URL="mysql://root:123456@localhost:3306/ap"
# 与 OMS 保持一致
JWT_SECRET="please-change-me-use-openssl-rand-base64-32"

# 可选：额外允许的 dev 来源主机名（逗号分隔）。next.config 已内置 192.168/10/172 私网通配，一般不必填
# NEXT_DEV_ALLOWED_HOSTS=

# 陌拜地图（与 mobile/h5 相同变量名）
# 高德开放平台 → 应用管理 → 创建「Web 端(JS API)」Key → 同一应用下复制「安全密钥」
# 复制本文件为 .env.local 后填写，改完需重启 dev
NEXT_PUBLIC_AMAP_KEY=
NEXT_PUBLIC_AMAP_SECURITY_JS_CODE=
