# 复制为仓库根目录的 .env 后填写（docker compose 会自动读取）
#   cp docker-compose.env.example .env

# 容器访问「宿主机」MySQL：用 host.docker.internal（docker-compose.yml 已配置 host-gateway）
DATABASE_URL="mysql://root:你的数据库密码@host.docker.internal:3306/ap"

# OMS 与 CRM 必须一致
JWT_SECRET="请用 openssl rand -base64 32 生成"

# CRM 陌拜地图（构建镜像时需要，改后需重新 docker compose build crm）
NEXT_PUBLIC_AMAP_KEY=
NEXT_PUBLIC_AMAP_SECURITY_JS_CODE=
